# ===============================
# Produccion — copiar a .env.production y completar valores
# NO commitear .env.production (contiene secretos)
# ===============================
PORT=3000
NODE_ENV=production
SWAGGER_ENABLED=false

# ===============================
# Base de datos (Docker prod: backend-db)
# ===============================
DB_HOST=backend-db
DB_PORT=5432
DB_NAME=TintasDB
DB_USERNAME=tintas_app
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_SYNC=false
DB_MIGRATIONS_RUN=true

# Desactivar seed automatico en produccion
SEED_ON_START=false
# Desactivar endpoint publico POST /api/seed/init
SEED_ENDPOINT_ENABLED=false

# ===============================
# JWT (generar: openssl rand -hex 64)
# ===============================
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=10h

# ===============================
# CORS y URLs publicas
# ===============================
CORS_ORIGIN=https://tudominio.com
PUBLIC_APP_URL=https://tudominio.com

# ===============================
# Auditoria
# ===============================
SYSTEM_AUDIT_USER_ID=00000000-0000-4000-8000-000000000001

# ===============================
# Evolution API (solo red interna Docker)
# ===============================
EVOLUTION_API_KEY=CHANGE_ME_EVOLUTION_KEY
INSTANCE_NAME=senor-tintas-prod
EVOLUTION_URL=http://evolution:8080
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# ===============================
# Restriccion WiFi empleados (CIDR separados por coma)
# Vacio = sin restriccion (no recomendado en prod)
# ===============================
ALLOWED_IPS=192.168.1.0/24

# ===============================
# DeepSeek AI
# ===============================
DEEPSEEK_API_KEY=CHANGE_ME_DEEPSEEK_KEY

# ===============================
# Chatbot — vacio en prod para atender a todos
# ===============================
WHITELIST_NUMBERS=
