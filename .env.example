# ===============================
# PostgreSQL
# ===============================
DB_PASSWORD=your_secure_password

# ===============================
# Evolution API
# ===============================
EVOLUTION_API_KEY=your_evolution_api_key
INSTANCE_API_KEY=your_instance_api_key
INSTANCE_NAME=senorbot

# ===============================
# Backend NestJS
# ===============================
NODE_ENV=development
PORT=3000

# Configuración de Base de Datos (Docker)
DB_HOST=backend-db
DB_PORT=5432
DB_NAME=backend
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password
DB_SYNC=true

# ===============================
# JWT Auth
# ===============================
JWT_SECRET=your_secure_jwt_secret_key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_DAYS=7

# ===============================
# Chatbot (Evolution API URL)
# ===============================
EVOLUTION_URL=http://evolution:8080

# ===============================
# Auditoría (Usuario del sistema)
# ===============================
SYSTEM_AUDIT_USER_ID=00000000-0000-4000-8000-000000000001

# ===============================
# Seguridad
# ===============================
# Origenes permitidos para CORS (separados por coma)
CORS_ORIGIN=http://localhost:3001,http://localhost:5173