# ===============================
# PostgreSQL
# ===============================
# Contraseña para ambas bases de datos
DB_PASSWORD=your_secure_password

# ===============================
# Evolution API
# ===============================
# Obtén tu API Key desde el panel de Evolution API
EVOLUTION_API_KEY=your_evolution_api_key
INSTANCE_NAME=Señor_de_las_Tintas

# ===============================
# Backend NestJS
# ===============================
PORT=3000

# Configuración de Base de Datos (Docker)
DB_HOST=backend-db
DB_PORT=5432
DB_NAME=backend
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password
DB_SYNC=true

# ===============================
# Chatbot (Evolution API URL)
# ===============================
# No cambiar - URL del servicio de Evolution en Docker
EVOLUTION_URL=http://evolution:8080

# ===============================
# Auditoría (Usuario del sistema)
# ===============================
# ID del usuario sistema para auditorías
SYSTEM_AUDIT_USER_ID=00000000-0000-4000-8000-000000000001