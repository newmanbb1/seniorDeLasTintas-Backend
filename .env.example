# ===============================
# Backend NestJS
# ===============================
PORT=3000
NODE_ENV=production

# Swagger UI (true/false — deshabilitar en producción si no se necesita)
SWAGGER_ENABLED=false

# ===============================
# Base de datos
# ===============================
# Para Docker: DB_HOST=backend-db
# Para local: DB_HOST=localhost
DB_HOST=localhost
DB_PORT=5432
DB_NAME=backend
DB_USERNAME=postgres
DB_PASSWORD=change-this-to-a-secure-password
DB_SYNC=false

# ===============================
# JWT Auth (generar con: openssl rand -hex 64)
JWT_SECRET=change-this-to-a-secure-random-string
JWT_REFRESH_SECRET=change-this-to-another-different-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=10h

# ===============================
# CORS
# ===============================
# Origen(es) permitidos separados por coma
# En production debe coincidir con el dominio del frontend
CORS_ORIGIN=https://tudominio.com

# ===============================
# Auditoría (Usuario del sistema)
# ===============================
SYSTEM_AUDIT_USER_ID=00000000-0000-4000-8000-000000000001

# ===============================
# Evolution API (WhatsApp)
# ===============================
EVOLUTION_API_KEY=your-evolution-api-key
INSTANCE_API_KEY=your-instance-api-key
INSTANCE_NAME=your-instance-name
EVOLUTION_URL=http://evolution:8080
WEBHOOK_SECRET=generate-a-random-secret-for-webhook-verification

# ===============================
# WiFi Access Restriction (login empleado)
# ===============================
# Rangos CIDR permitidos separados por coma
# Vacío = sin restricción (desarrollo)
ALLOWED_IPS=

# ===============================
# DeepSeek AI API
# ===============================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ===============================
# Modo Prueba Chatbot (opcional)
# ===============================
# Vacío = modo normal (responde a todos excepto propio)
# Números separados por coma = modo prueba (solo responde a esos)
# Ej: WHITELIST_NUMBERS=62454434,59167645041
WHITELIST_NUMBERS=
